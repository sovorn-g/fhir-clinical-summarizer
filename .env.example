# copy to .env and fill in. Never commit .env.
#
# LLM provider + model via LiteLLM ("provider/model"). LiteLLM reads the matching
# key env var automatically (ANTHROPIC_API_KEY, OPENAI_API_KEY, ...).
LLM_MODEL=anthropic/claude-opus-4-8

# Cheap / fast model for dev runs and the faithfulness judge can be pinned separately.
# CONTRACTS §6 pins the judge to claude-opus-4-8; override only for experimentation.
LLM_JUDGE_MODEL=anthropic/claude-opus-4-8

# API keys (uncomment the one(s) you use)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Summarizer behaviour
CLINICAL_LLM_TEMPERATURE=0.0
CLINICAL_LLM_MAX_TOKENS=1500

# Faithfulness gate
FAITHFULNESS_THRESHOLD=0.95

# Filtered-view sizes (CONTRACTS §4) — tunable without code edits
RECENT_ENCOUNTERS_N=5
ABNORMAL_RESULTS_N=10